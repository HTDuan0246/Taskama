{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "server=${DB_HOST};database=${DB_NAME};uid=${DB_USER};pwd=${DB_PASS};TrustServerCertificate=True;Trusted_Connection=False"
  },
  "AllowedHosts": "*"
}